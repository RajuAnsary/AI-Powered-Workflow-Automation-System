# MongoDB Atlas connection string
# Get this from your MongoDB Atlas cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/biztelai?retryWrites=true&w=majority

# Groq API key (completely free — get yours at https://console.groq.com/keys)
# No credit card required, generous free tier with no daily quota issues
GROQ_API_KEY=your-groq-api-key-here

# Port the Express server listens on (Render sets this automatically)
PORT=5000

# URL of the deployed frontend (used for CORS — no trailing slash)
FRONTEND_URL=https://your-app.vercel.app
